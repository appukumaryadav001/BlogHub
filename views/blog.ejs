<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("./partials/head")%>
    <title>Blog</title>
</head>
<body>
    <%- include("./partials/nav")%>
      <div class="container mt-4">
        <img src="<%=blog.createdBy.avatar%>" style="height:40px; border-radius:50%; object-fit:cover;" alt=""> 
        <%=blog.createdBy.fullName%>
      </div>
      <div class="container mt-4 mb-4">
        <h1><%=blog.title%></h1>
        <img src="<%=blog.coverImageURL%>" width="400px" alt="...">
        <div class="blog-page">

        <pre  class="mt-3 text-wrap overflow-hidden"><%=blog.body%></pre>
      </div>

    
    <%- include("./partials/scripts")%>
</body>
</html>